<Window x:Class="FfxiTempLogCollector.App.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="LogRep2 オーバーレイ"
        Width="420"
        Height="300"
        MinWidth="280"
        MinHeight="180"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Opacity="{Binding OverlayOpacity}"
        Topmost="{Binding Topmost}">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibility" />
    </Window.Resources>
    <Border x:Name="DragSurface"
            Background="#E6121B26"
            BorderBrush="#809BB0C2"
            BorderThickness="1"
            CornerRadius="6"
            MouseLeftButtonDown="OnDragSurfaceMouseLeftButtonDown">
        <Grid Margin="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0">
                <TextBlock VerticalAlignment="Center"
                           Foreground="White"
                           FontSize="{Binding FontSize}"
                           FontWeight="Bold"
                           Text="LogRep2" />
                <StackPanel DockPanel.Dock="Right"
                            Cursor="Arrow"
                            Orientation="Horizontal">
                    <Button MinWidth="48"
                            Height="26"
                            Margin="4,0,0,0"
                            Command="{Binding HideCommand}"
                            Content="非表示" />
                </StackPanel>
            </DockPanel>

            <Grid Grid.Row="1"
                  Margin="0,12,0,0"
                  Visibility="{Binding HasPartyMembers, Converter={StaticResource BooleanToVisibility}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="110" />
                    <ColumnDefinition Width="100" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Foreground="#B8C7D5" FontWeight="SemiBold" Text="メンバー" />
                <TextBlock Grid.Column="1" Foreground="#B8C7D5" FontWeight="SemiBold" TextAlignment="Right" Text="DPS" />
                <TextBlock Grid.Column="2" Foreground="#B8C7D5" FontWeight="SemiBold" TextAlignment="Right" Text="通常命中率" />
                <ItemsControl Grid.Row="1" Grid.ColumnSpan="3" Margin="0,6,0,0"
                              ItemsSource="{Binding PartyMembers}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="110" />
                                <ColumnDefinition Width="100" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Foreground="White"
                                       FontSize="{Binding DataContext.FontSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                       Text="{Binding Name}" TextTrimming="CharacterEllipsis" />
                            <TextBlock Grid.Column="1" Foreground="White" TextAlignment="Right"
                                       FontSize="{Binding DataContext.FontSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                       Text="{Binding Dps}" />
                            <TextBlock Grid.Column="2" Foreground="White" TextAlignment="Right"
                                       FontSize="{Binding DataContext.FontSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                       Text="{Binding HitRate}" />
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>

            <Border Grid.Row="1"
                    Margin="0,12,0,0"
                    Padding="18"
                    Background="#802A3542"
                    CornerRadius="4"
                    Visibility="{Binding ShowEmptyPartyState, Converter={StaticResource BooleanToVisibility}}">
                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Cursor="Arrow">
                    <TextBlock HorizontalAlignment="Center"
                               Foreground="#FFD166"
                               FontSize="{Binding FontSize}"
                               FontWeight="SemiBold"
                               Text="PTメンバーが設定されていません" />
                    <TextBlock Margin="0,8,0,12"
                               HorizontalAlignment="Center"
                               Foreground="White"
                               Text="DPS／通常命中率を表示するには、PTメンバーを登録してください。"
                               TextAlignment="Center"
                               TextWrapping="Wrap" />
                    <Button Width="176"
                            Height="32"
                            HorizontalAlignment="Center"
                            Command="{Binding OpenPartyMemberSettingsCommand}"
                            Content="PTメンバー設定を開く" />
                </StackPanel>
            </Border>

            <StackPanel Grid.Row="2"
                        Margin="0,8,0,0"
                        Cursor="Arrow"
                        Orientation="Horizontal">
                <TextBlock VerticalAlignment="Center" Foreground="#B8C7D5" Text="更新: " />
                <TextBlock VerticalAlignment="Center" Foreground="#B8C7D5" Text="{Binding LastUpdated}" />
                <TextBlock Margin="16,0,4,0" VerticalAlignment="Center" Foreground="#B8C7D5" Text="透明度" />
                <Slider Width="80" Minimum="0.25" Maximum="1" Value="{Binding OverlayOpacity}" />
                <TextBlock Margin="12,0,4,0" VerticalAlignment="Center" Foreground="#B8C7D5" Text="文字" />
                <Slider Width="60" Minimum="10" Maximum="40" Value="{Binding FontSize}" />
                <CheckBox Margin="16,0,0,0" VerticalAlignment="Center" Foreground="White" IsChecked="{Binding Topmost}" Content="最前面" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
