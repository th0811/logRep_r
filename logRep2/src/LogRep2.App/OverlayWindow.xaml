<Window x:Class="FfxiTempLogCollector.App.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="LogRep2 オーバーレイ"
        Width="420"
        Height="300"
        MinWidth="280"
        MinHeight="180"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Opacity="{Binding OverlayOpacity}"
        Topmost="{Binding Topmost}">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibility" />
    </Window.Resources>
    <Border Background="#E6121B26"
            BorderBrush="#809BB0C2"
            BorderThickness="1"
            CornerRadius="6">
        <Grid Margin="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0">
                <TextBlock VerticalAlignment="Center"
                           Foreground="White"
                           FontSize="{Binding FontSize}"
                           FontWeight="Bold"
                           MouseLeftButtonDown="OnDragAreaMouseLeftButtonDown"
                           Text="LogRep2" />
                <StackPanel DockPanel.Dock="Right"
                            Orientation="Horizontal">
                    <Button MinWidth="48"
                            Height="26"
                            Margin="4,0,0,0"
                            Command="{Binding ToggleEditingCommand}"
                            Content="{Binding EditButtonText}" />
                    <Button MinWidth="72"
                            Height="26"
                            Margin="4,0,0,0"
                            Command="{Binding ResetPositionCommand}"
                            Content="位置リセット" />
                    <Button MinWidth="48"
                            Height="26"
                            Margin="4,0,0,0"
                            Command="{Binding HideCommand}"
                            Content="非表示" />
                </StackPanel>
            </DockPanel>

            <Grid Grid.Row="1" Margin="0,12,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0"
                            Visibility="{Binding ShowAnalysisState, Converter={StaticResource BooleanToVisibility}}">
                    <TextBlock Foreground="#B8C7D5" Text="状態" />
                    <TextBlock Foreground="White" FontSize="{Binding FontSize}" FontWeight="SemiBold" Text="{Binding StateText}" />
                </StackPanel>
                <StackPanel Grid.Column="1"
                            Visibility="{Binding ShowTotalDamage, Converter={StaticResource BooleanToVisibility}}">
                    <TextBlock Foreground="#B8C7D5" Text="合計ダメージ" />
                    <TextBlock Foreground="White" FontSize="{Binding FontSize}" FontWeight="SemiBold" Text="{Binding TotalDamage, StringFormat=N0}" />
                </StackPanel>
                <StackPanel Grid.Column="2"
                            Visibility="{Binding ShowDpsOrHitRate, Converter={StaticResource BooleanToVisibility}}">
                    <TextBlock Foreground="#B8C7D5" Text="DPS / 命中率" />
                    <TextBlock Foreground="White" FontSize="{Binding FontSize}" FontWeight="SemiBold">
                        <Run Text="{Binding Dps, Mode=OneWay}" /><Run Text=" / " /><Run Text="{Binding HitRate, Mode=OneWay}" />
                    </TextBlock>
                </StackPanel>
            </Grid>

            <ItemsControl Grid.Row="2"
                          ItemsSource="{Binding ActorRankings}"
                          Visibility="{Binding ShowActorRanking, Converter={StaticResource BooleanToVisibility}}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Margin="0,2"
                                   Foreground="White"
                                   FontSize="{Binding DataContext.FontSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                   Text="{Binding}" />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <StackPanel Grid.Row="3"
                        Margin="0,8,0,0"
                        Orientation="Horizontal">
                <TextBlock VerticalAlignment="Center" Foreground="#B8C7D5" Text="更新: " />
                <TextBlock VerticalAlignment="Center" Foreground="#B8C7D5" Text="{Binding LastUpdated}" />
                <TextBlock Margin="16,0,4,0" VerticalAlignment="Center" Foreground="#B8C7D5" Text="透明度" />
                <Slider Width="80" Minimum="0.25" Maximum="1" Value="{Binding OverlayOpacity}" />
                <TextBlock Margin="12,0,4,0" VerticalAlignment="Center" Foreground="#B8C7D5" Text="文字" />
                <Slider Width="60" Minimum="10" Maximum="40" Value="{Binding FontSize}" />
                <CheckBox Margin="16,0,0,0" VerticalAlignment="Center" Foreground="White" IsChecked="{Binding Topmost}" Content="最前面" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
