<Window x:Class="FfxiTempLogCollector.App.PartyMemberManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PTメンバー設定"
        Width="680"
        Height="480"
        MinWidth="580"
        MinHeight="400"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="18" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <GroupBox Grid.Column="0" Header="{Binding CountText}" Padding="10">
                <DockPanel>
                    <Grid DockPanel.Dock="Top" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="64" />
                        </Grid.ColumnDefinitions>
                        <TextBox Margin="0,0,8,0"
                                 Text="{Binding NameInput, UpdateSourceTrigger=PropertyChanged}" />
                        <Button Grid.Column="1" Command="{Binding AddNameCommand}" Content="追加" />
                    </Grid>
                    <StackPanel DockPanel.Dock="Bottom" Margin="0,8,0,0" Orientation="Horizontal">
                        <Button Width="64" Margin="0,0,6,0" Command="{Binding MoveUpCommand}" Content="上へ" />
                        <Button Width="64" Margin="0,0,6,0" Command="{Binding MoveDownCommand}" Content="下へ" />
                        <Button Width="64" Command="{Binding RemoveCommand}" Content="削除" />
                    </StackPanel>
                    <ListBox ItemsSource="{Binding Members}" SelectedItem="{Binding SelectedMember}" />
                </DockPanel>
            </GroupBox>
            <GroupBox Grid.Column="2" Header="ログから検出したPC候補" Padding="10">
                <DockPanel>
                    <Button DockPanel.Dock="Bottom" Height="30" Margin="0,8,0,0"
                            Command="{Binding AddCandidateCommand}" Content="選択した候補を追加" />
                    <TextBlock DockPanel.Dock="Top" Margin="0,0,0,8" TextWrapping="Wrap"
                               Text="ログに登場したPC候補です。PT所属を確認して追加してください。" />
                    <ListBox ItemsSource="{Binding Candidates}" SelectedItem="{Binding SelectedCandidate}" />
                </DockPanel>
            </GroupBox>
        </Grid>
        <DockPanel Grid.Row="1" Margin="0,14,0,0">
            <Button DockPanel.Dock="Left" Width="96" Height="32"
                    Command="{Binding ClearCommand}" Content="全解除" />
            <Button DockPanel.Dock="Right" Width="96" Height="32"
                    IsCancel="True" Content="閉じる" />
        </DockPanel>
    </Grid>
</Window>
