<Window x:Class="FFXI_LogAnalyzer.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FFXI_LogAnalyzer.App"
        mc:Ignorable="d"
        Title="LogRep2 - 過去ログ分析" Height="900" Width="1600" MinHeight="520" MinWidth="760">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <Style TargetType="Button">
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="MinWidth" Value="120" />
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
    </Window.Resources>

    <DockPanel Margin="16">
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,12">
            <Button Content="セッション出力先選択" Command="{Binding SelectSessionRootFolderCommand}" />
            <Button Content="更新" Command="{Binding RefreshSessionsCommand}" />
            <Button Content="選択解除" Command="{Binding RemoveSelectedSessionCommand}" />
            <Button Content="すべて解除" Command="{Binding ClearSessionsCommand}" />
            <TextBlock Text="{Binding StatusMessage}" Margin="8,0,0,0" TextWrapping="Wrap" />
        </StackPanel>

        <Border DockPanel.Dock="Top" BorderBrush="#D0D7DE" BorderThickness="1" Padding="10" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="読み込み状態" FontWeight="Bold" Margin="0,0,0,6" />
                <TextBlock Text="セッション出力先" FontWeight="Bold" />
                <TextBlock Text="{Binding SessionRootFolderPath}" TextWrapping="Wrap" Margin="0,0,0,6" />
                <TextBlock Text="分析対象" FontWeight="Bold" />
                <TextBlock Text="{Binding SelectedFolderPath}" TextWrapping="Wrap" />
                <TextBlock Text="セッションフォルダ選択後は、分析区間タブに進んでください" Margin="0,8,0,0" />
            </StackPanel>
        </Border>

        <TabControl>
            <TabItem Header="セッション情報">
                <Grid Margin="0,8,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="2*" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <GroupBox Header="選択済みセッション" Grid.Row="0" Grid.ColumnSpan="2" Margin="0,0,0,0">
                        <DataGrid ItemsSource="{Binding Sessions}"
                                  SelectedItem="{Binding SelectedSession, Mode=TwoWay}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  IsReadOnly="False"
                                  HeadersVisibility="Column">
                            <DataGrid.Columns>
                                <DataGridCheckBoxColumn Header="使用" Binding="{Binding IsEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="60" />
                                <DataGridTextColumn Header="セッションID" Binding="{Binding SessionId}" Width="150" IsReadOnly="True" />
                                <DataGridTextColumn Header="開始時刻" Binding="{Binding StartedAt}" Width="170" IsReadOnly="True" />
                                <DataGridTextColumn Header="終了時刻" Binding="{Binding EndedAt}" Width="170" IsReadOnly="True" />
                                <DataGridTextColumn Header="レコード数" Binding="{Binding RecordCount}" Width="100" IsReadOnly="True" />
                                <DataGridTextColumn Header="マーカー数" Binding="{Binding MarkerCount}" Width="100" IsReadOnly="True" />
                                <DataGridTextColumn Header="状態" Binding="{Binding Status}" Width="100" IsReadOnly="True" />
                                <DataGridTextColumn Header="フォルダ" Binding="{Binding FolderPath}" Width="*" IsReadOnly="True" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </GroupBox>

                    <GroupBox Header="セッション情報" Grid.Row="2" Grid.Column="0" Margin="0,0,12,0">
                        <DataGrid ItemsSource="{Binding SessionInfoRows}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  IsReadOnly="True"
                                  HeadersVisibility="Column"
                                  Visibility="{Binding HasSession, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="項目" Binding="{Binding Label}" Width="220" />
                                <DataGridTextColumn Header="値" Binding="{Binding Value}" Width="*" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </GroupBox>

                    <GroupBox Header="警告" Grid.Row="2" Grid.Column="1">
                        <ListBox ItemsSource="{Binding Warnings}" />
                    </GroupBox>
                </Grid>
            </TabItem>

            <TabItem Header="分析区間">
                <local:AnalysisRangeSelectionView DataContext="{Binding AnalysisRange}" Margin="0,8,0,0" />
            </TabItem>

            <TabItem Header="分析結果">
                <local:AnalysisResultView DataContext="{Binding AnalysisResult}" Margin="0,8,0,0" />
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
