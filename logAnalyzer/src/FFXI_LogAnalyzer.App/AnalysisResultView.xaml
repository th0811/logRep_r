<UserControl x:Class="FFXI_LogAnalyzer.App.AnalysisResultView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:FFXI_LogAnalyzer.App"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="420"
             d:DesignWidth="900">
    <UserControl.Resources>
        <Style x:Key="CompactButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="10,4" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="MinWidth" Value="96" />
        </Style>
        <Style x:Key="FilterCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="Margin" Value="0,0,12,4" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
    </UserControl.Resources>

    <DockPanel>
        <TextBlock DockPanel.Dock="Top"
                   Text="{Binding StatusMessage}"
                   FontWeight="Bold"
                   Margin="0,0,0,8" />

        <TabControl>
            <TabItem Header="キャラクター別サマリ">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="360" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <GroupBox Grid.Column="0"
                              Header="actor選択"
                              Padding="8">
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Top">
                                <TextBox Text="{Binding ActorFilterText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         MinWidth="220"
                                         Margin="0,0,0,8" />

                                <WrapPanel Margin="0,0,0,4">
                                    <CheckBox Style="{StaticResource FilterCheckBoxStyle}"
                                              Content="PC登録"
                                              IsChecked="{Binding ShowRegisteredPcActors, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <CheckBox Style="{StaticResource FilterCheckBoxStyle}"
                                              Content="PC候補"
                                              IsChecked="{Binding ShowPcCandidateActors, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <CheckBox Style="{StaticResource FilterCheckBoxStyle}"
                                              Content="NPC登録"
                                              IsChecked="{Binding ShowRegisteredNpcActors, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <CheckBox Style="{StaticResource FilterCheckBoxStyle}"
                                              Content="未分類"
                                              IsChecked="{Binding ShowUnknownActors, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </WrapPanel>

                                <UniformGrid Columns="2"
                                             Margin="0,0,0,8">
                                    <Button Style="{StaticResource CompactButtonStyle}"
                                            Content="すべて選択"
                                            Command="{Binding SelectAllActorsCommand}" />
                                    <Button Style="{StaticResource CompactButtonStyle}"
                                            Content="すべて解除"
                                            Command="{Binding ClearActorSelectionCommand}" />
                                    <Button Style="{StaticResource CompactButtonStyle}"
                                            Content="PC候補を選択"
                                            Command="{Binding SelectPcCandidateActorsCommand}" />
                                    <Button Style="{StaticResource CompactButtonStyle}"
                                            Content="登録済みPCのみ"
                                            Command="{Binding SelectRegisteredPcActorsCommand}" />
                                </UniformGrid>

                                <DockPanel Margin="0,0,0,8">
                                    <Button DockPanel.Dock="Left"
                                            Style="{StaticResource CompactButtonStyle}"
                                            Content="登録名管理"
                                            Command="{Binding OpenActorRegistrationManagerCommand}" />
                                    <TextBlock Text="{Binding ActorSelectionSummary}"
                                               VerticalAlignment="Center"
                                               Margin="8,0,0,0" />
                                </DockPanel>
                            </StackPanel>

                            <ListBox ItemsSource="{Binding FilteredActorVisibilities}"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="4"
                                                BorderBrush="#E5E7EB"
                                                BorderThickness="0,0,0,1">
                                            <Border.ContextMenu>
                                                <ContextMenu>
                                                    <MenuItem Header="PC名として登録"
                                                              Command="{Binding PlacementTarget.DataContext.RegisterAsPcCommand,
                                                                                RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                                    <MenuItem Header="NPC名として登録"
                                                              Command="{Binding PlacementTarget.DataContext.RegisterAsNpcCommand,
                                                                                RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                                    <MenuItem Header="登録を解除"
                                                              Command="{Binding PlacementTarget.DataContext.ClearRegistrationCommand,
                                                                                RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                                </ContextMenu>
                                            </Border.ContextMenu>

                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <CheckBox Grid.Column="0"
                                                          Content="{Binding Actor}"
                                                          IsChecked="{Binding IsVisible, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                          VerticalAlignment="Center" />
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding ClassificationLabel}"
                                                           HorizontalAlignment="Right"
                                                           VerticalAlignment="Center"
                                                           Padding="8,2"
                                                           Foreground="{Binding ClassificationForeground}"
                                                           Background="{Binding ClassificationBackground}" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </DockPanel>
                    </GroupBox>

                    <DataGrid Grid.Column="2"
                              ItemsSource="{Binding ActorSummaries}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="True"
                              HeadersVisibility="Column">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="actor名" Binding="{Binding Actor}" Width="150" />
                            <DataGridTextColumn Header="総与ダメージ" Binding="{Binding TotalDamage}" Width="110" />
                            <DataGridTextColumn Header="DPS" Binding="{Binding Dps}" Width="90" />
                            <DataGridTextColumn Header="DPS時間信頼度" Binding="{Binding DpsTimeConfidence}" Width="120" />
                            <DataGridTextColumn Header="通常攻撃命中率" Binding="{Binding NormalAttackHitRate}" Width="150" />
                            <DataGridTextColumn Header="通常攻撃クリティカル率" Binding="{Binding NormalAttackCriticalRate}" Width="170" />
                            <DataGridTextColumn Header="unknown件数" Binding="{Binding UnknownCount}" Width="100" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <TabItem Header="技/魔法/通常攻撃別集計">
                <DataGrid ItemsSource="{Binding ActionSummaries}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          IsReadOnly="True"
                          HeadersVisibility="Column">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="actor名" Binding="{Binding Actor}" Width="140" />
                        <DataGridTextColumn Header="action_name" Binding="{Binding ActionName}" Width="170" />
                        <DataGridTextColumn Header="action_type" Binding="{Binding ActionType}" Width="140" />
                        <DataGridTextColumn Header="使用回数" Binding="{Binding UseCount}" Width="90" />
                        <DataGridTextColumn Header="命中回数" Binding="{Binding HitCount}" Width="90" />
                        <DataGridTextColumn Header="非命中回数" Binding="{Binding MissCount}" Width="100" />
                        <DataGridTextColumn Header="unknown件数" Binding="{Binding UnknownCount}" Width="100" />
                        <DataGridTextColumn Header="命中率" Binding="{Binding HitRate}" Width="90" />
                        <DataGridTextColumn Header="総ダメージ" Binding="{Binding TotalDamage}" Width="100" />
                        <DataGridTextColumn Header="最大ダメージ" Binding="{Binding MaxDamage}" Width="100" />
                        <DataGridTextColumn Header="最小ダメージ" Binding="{Binding MinDamage}" Width="100" />
                        <DataGridTextColumn Header="平均ダメージ" Binding="{Binding AverageDamage}" Width="100" />
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <TabItem Header="レベル上げ">
                <DataGrid ItemsSource="{Binding LevelingPointSummaries}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          IsReadOnly="True"
                          HeadersVisibility="Column">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ポイント種別" Binding="{Binding PointName}" Width="220" />
                        <DataGridTextColumn Header="総合計" Binding="{Binding TotalPoints}" Width="140" />
                        <DataGridTextColumn Header="時給" Binding="{Binding PointsPerHour}" Width="140" />
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <TabItem Header="未解析ログ">
                <local:UnparsedLogView />
            </TabItem>

            <TabItem Header="セッション情報">
                <DataGrid ItemsSource="{Binding SessionRows}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          IsReadOnly="True"
                          HeadersVisibility="Column">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="項目" Binding="{Binding Label}" Width="240" />
                        <DataGridTextColumn Header="値" Binding="{Binding Value}" Width="*" />
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
        </TabControl>
    </DockPanel>
</UserControl>
