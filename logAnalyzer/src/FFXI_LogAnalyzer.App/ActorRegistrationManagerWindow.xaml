<Window x:Class="FFXI_LogAnalyzer.App.ActorRegistrationManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PC/NPC登録名管理"
        Height="460"
        Width="720"
        MinHeight="360"
        MinWidth="620"
        WindowStartupLocation="CenterOwner">
    <DockPanel Margin="16">
        <TextBlock DockPanel.Dock="Top"
                   Text="PC名は先頭大文字、2文字目以降小文字へ正規化して保存します。NPC名は入力した表示名を保存します。"
                   TextWrapping="Wrap"
                   Margin="0,0,0,12" />

        <Button DockPanel.Dock="Bottom"
                HorizontalAlignment="Right"
                Width="96"
                Height="32"
                Margin="0,12,0,0"
                Content="閉じる"
                IsCancel="True" />

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <GroupBox Grid.Column="0"
                      Header="PC名として扱う名前"
                      Padding="10">
                <DockPanel>
                    <Grid DockPanel.Dock="Top"
                          Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="80" />
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0"
                                 MinWidth="220"
                                 HorizontalAlignment="Stretch"
                                 Text="{Binding PcNameInput,
                                                UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,8,0" />
                        <Button Grid.Column="1"
                                Content="追加"
                                Command="{Binding AddPcNameCommand}" />
                    </Grid>

                    <Button DockPanel.Dock="Bottom"
                            Height="30"
                            Margin="0,8,0,0"
                            Content="選択を削除"
                            Command="{Binding RemovePcNameCommand}" />

                    <ListBox ItemsSource="{Binding PcNames}"
                             SelectedItem="{Binding SelectedPcName}" />
                </DockPanel>
            </GroupBox>

            <GroupBox Grid.Column="2"
                      Header="NPC名として扱う名前"
                      Padding="10">
                <DockPanel>
                    <Grid DockPanel.Dock="Top"
                          Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="80" />
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0"
                                 MinWidth="220"
                                 HorizontalAlignment="Stretch"
                                 Text="{Binding NpcNameInput,
                                                UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,8,0" />
                        <Button Grid.Column="1"
                                Content="追加"
                                Command="{Binding AddNpcNameCommand}" />
                    </Grid>

                    <Button DockPanel.Dock="Bottom"
                            Height="30"
                            Margin="0,8,0,0"
                            Content="選択を削除"
                            Command="{Binding RemoveNpcNameCommand}" />

                    <ListBox ItemsSource="{Binding NpcNames}"
                             SelectedItem="{Binding SelectedNpcName}" />
                </DockPanel>
            </GroupBox>
        </Grid>
    </DockPanel>
</Window>
