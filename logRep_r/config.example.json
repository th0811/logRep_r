{
  "temp_dir": "",
  "output_dir": "sessions",
  "encoding": "cp932",
  "polling_interval_ms": 1000,
  "watch_window1": true,
  "watch_window2": true,
  "rotation_slots": 20,
  "raw_output": true,
  "canonical_output": true,
  "dedupe_raw": true,
  "dedupe_canonical": true,
  "marker_detection": true,
  "marker_prefix": "###",
  "timezone": "Asia/Tokyo",
  "flush_interval_ms": 1000,
  "hash_algorithm": "sha1",
  "log_level": "info",
  "auto_start_collection_on_launch": false,
  "minimize_to_tray_while_collecting": false,
  "minimize_button_behavior": "tray",
  "close_button_behavior": "tray_when_collecting",
  "show_tray_notifications": true
}
