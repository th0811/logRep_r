<Window x:Class="FfxiTempLogCollector.App.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="設定"
        Height="650"
        Width="700"
        MinHeight="560"
        MinWidth="620"
        WindowStartupLocation="CenterOwner"
        PreviewKeyDown="OnPreviewKeyDown">
    <Grid Background="#F4F6F8">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0"
                      Padding="24"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <GroupBox Header="収集対象と出力先"
                          Padding="16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="90" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Grid.Column="0"
                                   Margin="0,0,12,12"
                                   VerticalAlignment="Center"
                                   Text="TEMPフォルダー" />
                        <TextBox Grid.Row="0"
                                 Grid.Column="1"
                                 Margin="0,0,8,12"
                                 Text="{Binding TempDirectory,
                                                UpdateSourceTrigger=PropertyChanged}" />
                        <Button Grid.Row="0"
                                Grid.Column="2"
                                Height="28"
                                Margin="0,0,0,12"
                                Command="{Binding SelectTempDirectoryCommand}"
                                Content="参照..." />

                        <TextBlock Grid.Row="1"
                                   Grid.Column="0"
                                   Margin="0,0,12,0"
                                   VerticalAlignment="Center"
                                   Text="出力先フォルダー" />
                        <TextBox Grid.Row="1"
                                 Grid.Column="1"
                                 Margin="0,0,8,0"
                                 Text="{Binding OutputDirectory,
                                                UpdateSourceTrigger=PropertyChanged}" />
                        <Button Grid.Row="1"
                                Grid.Column="2"
                                Height="28"
                                Command="{Binding SelectOutputDirectoryCommand}"
                                Content="参照..." />
                    </Grid>
                </GroupBox>

                <GroupBox Margin="0,16,0,0"
                          Header="収集設定"
                          Padding="16">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,12">
                            <TextBlock Width="220"
                                       VerticalAlignment="Center"
                                       Text="ポーリング間隔（ms）" />
                            <TextBox Width="120"
                                     HorizontalAlignment="Left"
                                     Text="{Binding PollingIntervalText,
                                                    UpdateSourceTrigger=PropertyChanged}" />
                        </DockPanel>
                        <CheckBox Margin="0,0,0,10"
                                  IsChecked="{Binding WatchWindow1}"
                                  Content="ログウィンドウ1を監視する" />
                        <CheckBox Margin="0,0,0,10"
                                  IsChecked="{Binding WatchWindow2}"
                                  Content="ログウィンドウ2を監視する" />
                        <CheckBox Margin="0,0,0,10"
                                  IsChecked="{Binding RawOutput}"
                                  Content="raw出力を有効にする" />
                        <CheckBox Margin="0,0,0,12"
                                  IsChecked="{Binding CanonicalOutput}"
                                  Content="canonical出力を有効にする" />
                        <DockPanel>
                            <TextBlock Width="220"
                                       VerticalAlignment="Center"
                                       Text="ログレベル" />
                            <ComboBox Width="160"
                                      HorizontalAlignment="Left"
                                      SelectedValue="{Binding LogLevel}"
                                      SelectedValuePath="Tag">
                                <ComboBoxItem Tag="debug"
                                              Content="デバッグ" />
                                <ComboBoxItem Tag="info"
                                              Content="情報" />
                                <ComboBoxItem Tag="warning"
                                              Content="警告" />
                                <ComboBoxItem Tag="error"
                                              Content="エラー" />
                            </ComboBox>
                        </DockPanel>
                    </StackPanel>
                </GroupBox>

                <GroupBox Margin="0,16,0,0"
                          Header="起動とウィンドウ動作"
                          Padding="16">
                    <StackPanel>
                        <CheckBox Margin="0,0,0,10"
                                  IsChecked="{Binding AutoStartCollectionOnLaunch}"
                                  Content="起動時に自動で収集開始する" />
                        <CheckBox Margin="0,0,0,10"
                                  IsChecked="{Binding MinimizeToTrayWhileCollecting}"
                                  Content="収集開始後にタスクトレイへ格納する" />
                        <CheckBox Margin="0,0,0,12"
                                  IsChecked="{Binding MinimizeToTray}"
                                  Content="最小化操作でタスクトレイへ格納する" />
                        <CheckBox Margin="0,0,0,12"
                                  IsChecked="{Binding ShowTrayNotifications}"
                                  Content="タスクトレイ通知を表示する" />
                        <DockPanel>
                            <TextBlock Width="220"
                                       VerticalAlignment="Center"
                                       Text="閉じるボタン押下時" />
                            <ComboBox Width="230"
                                      HorizontalAlignment="Left"
                                      SelectedValue="{Binding CloseButtonBehavior}"
                                      SelectedValuePath="Tag">
                                <ComboBoxItem Tag="confirm_exit"
                                              Content="終了確認を表示する" />
                                <ComboBoxItem Tag="tray_when_collecting"
                                              Content="収集中のみ格納する" />
                                <ComboBoxItem Tag="always_tray"
                                              Content="常に格納する" />
                            </ComboBox>
                        </DockPanel>
                    </StackPanel>
                </GroupBox>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="1"
                Padding="16"
                Background="White"
                BorderBrush="#D9DEE5"
                BorderThickness="0,1,0,0">
            <StackPanel HorizontalAlignment="Right"
                        Orientation="Horizontal">
                <Button Width="96"
                        Height="34"
                        Margin="0,0,8,0"
                        Command="{Binding SaveCommand}"
                        Content="保存" />
                <Button Width="96"
                        Height="34"
                        Command="{Binding CancelCommand}"
                        Content="キャンセル" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
