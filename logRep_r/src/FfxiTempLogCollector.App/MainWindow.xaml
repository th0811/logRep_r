<Window x:Class="FfxiTempLogCollector.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="FFXI_LogRep_r"
        Height="590"
        Width="860"
        MinHeight="520"
        MinWidth="760"
        WindowStartupLocation="CenterScreen"
        Loaded="OnLoaded"
        StateChanged="OnStateChanged"
        Closing="OnClosing">
    <Grid Background="#F4F6F8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Padding="24,18"
                Background="#243447">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock Foreground="White"
                               FontSize="24"
                               FontWeight="SemiBold"
                               Text="FFXI_LogRep_r" />
                    <TextBlock Margin="0,4,0,0"
                               Foreground="#C9D4DF"
                               Text="TEMPログを継続的に退避します" />
                </StackPanel>
                <Border DockPanel.Dock="Right"
                        Margin="24,0,0,0"
                        Padding="16,8"
                        VerticalAlignment="Center"
                        Background="{Binding StatusBackground}"
                        CornerRadius="4">
                    <TextBlock Foreground="{Binding StatusForeground}"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Text="{Binding StatusText}" />
                </Border>
            </DockPanel>
        </Border>

        <ScrollViewer Grid.Row="1"
                      Padding="24"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <GroupBox Header="収集設定"
                          Padding="16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Grid.Column="0"
                                   Margin="0,0,12,12"
                                   FontWeight="SemiBold"
                                   Text="TEMPフォルダー" />
                        <TextBox Grid.Row="0"
                                 Grid.Column="1"
                                 Margin="0,0,0,12"
                                 IsReadOnly="True"
                                 Text="{Binding TempDirectory,
                                                Mode=OneWay}" />

                        <TextBlock Grid.Row="1"
                                   Grid.Column="0"
                                   Margin="0,0,12,0"
                                   FontWeight="SemiBold"
                                   Text="出力先フォルダー" />
                        <TextBox Grid.Row="1"
                                 Grid.Column="1"
                                 IsReadOnly="True"
                                 Text="{Binding OutputDirectory,
                                                Mode=OneWay}" />
                    </Grid>
                </GroupBox>

                <GroupBox Margin="0,16,0,0"
                          Header="収集状況"
                          Padding="16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="150" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Grid.Column="0"
                                   Margin="0,0,12,12"
                                   FontWeight="SemiBold"
                                   Text="セッションID" />
                        <TextBlock Grid.Row="0"
                                   Grid.Column="1"
                                   Margin="0,0,24,12"
                                   Text="{Binding SessionId}" />
                        <TextBlock Grid.Row="0"
                                   Grid.Column="2"
                                   Margin="0,0,12,12"
                                   FontWeight="SemiBold"
                                   Text="最終検出時刻" />
                        <TextBlock Grid.Row="0"
                                   Grid.Column="3"
                                   Margin="0,0,0,12"
                                   Text="{Binding LastSeenAt}" />

                        <TextBlock Grid.Row="1"
                                   Grid.Column="0"
                                   Margin="0,0,12,12"
                                   FontWeight="SemiBold"
                                   Text="raw保存件数" />
                        <TextBlock Grid.Row="1"
                                   Grid.Column="1"
                                   Margin="0,0,24,12"
                                   Text="{Binding RawRecordsWritten}" />
                        <TextBlock Grid.Row="1"
                                   Grid.Column="2"
                                   Margin="0,0,12,12"
                                   FontWeight="SemiBold"
                                   Text="canonical保存件数" />
                        <TextBlock Grid.Row="1"
                                   Grid.Column="3"
                                   Margin="0,0,0,12"
                                   Text="{Binding CanonicalRecordsWritten}" />

                        <TextBlock Grid.Row="2"
                                   Grid.Column="0"
                                   Margin="0,0,12,0"
                                   FontWeight="SemiBold"
                                   Text="警告数" />
                        <TextBlock Grid.Row="2"
                                   Grid.Column="1"
                                   Margin="0,0,24,0"
                                   Text="{Binding WarningCount}" />
                        <TextBlock Grid.Row="2"
                                   Grid.Column="2"
                                   Margin="0,0,12,0"
                                   FontWeight="SemiBold"
                                   Text="直近エラー" />
                        <TextBlock Grid.Row="2"
                                   Grid.Column="3"
                                   Foreground="#B42318"
                                   Text="{Binding LastError}"
                                   TextWrapping="Wrap" />
                    </Grid>
                </GroupBox>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2"
                Padding="20,14"
                Background="White"
                BorderBrush="#D9DEE5"
                BorderThickness="0,1,0,0">
            <DockPanel>
                <StackPanel DockPanel.Dock="Left"
                            Orientation="Horizontal">
                    <Button Width="104"
                            Height="34"
                            Margin="0,0,8,0"
                            Command="{Binding StartCommand}"
                            Content="収集開始" />
                    <Button Width="104"
                            Height="34"
                            Margin="0,0,16,0"
                            Command="{Binding StopCommand}"
                            Content="収集停止" />
                    <Button Width="90"
                            Height="34"
                            Margin="0,0,8,0"
                            Command="{Binding SettingsCommand}"
                            Content="設定" />
                    <Button Width="112"
                            Height="34"
                            Margin="0,0,8,0"
                            Command="{Binding OpenTempCommand}"
                            Content="TEMPを開く" />
                    <Button Width="112"
                            Height="34"
                            Command="{Binding OpenOutputCommand}"
                            Content="出力先を開く" />
                </StackPanel>

                <StackPanel DockPanel.Dock="Right"
                            Orientation="Horizontal">
                    <Button Width="128"
                            Height="34"
                            Margin="16,0,8,0"
                            Command="{Binding MinimizeCommand}"
                            Content="タスクトレイへ格納" />
                    <Button Width="80"
                            Height="34"
                            Command="{Binding ExitCommand}"
                            Content="終了" />
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</Window>
